//Nested Block Scope Tracking
#include <iostream>
using namespace std;

class Test {
private:
    int id;
public:
    Test(int i) {
        id = i;
        cout << "Construct " << id << endl;
    }
    ~Test() {
        cout << "Destruct " << id << endl;
    }
};

int main() {
    cout << "Main Start\n";
    Test t1(1);
    {
        cout << "Entering Block\n";
        Test t2(2);
        cout << "Exiting Block\n";
    }
    cout << "Main End\n";
    return 0;
}
