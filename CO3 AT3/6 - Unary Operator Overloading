//Unary Operator Overloading 
#include <iostream>
using namespace std;

class Number {
private:
    int value;

public:
    Number(int v) {
        value = v;
    }

    void operator-() {
        value = -value;
    }

    void display() const {
        cout << "Value: " << value << endl;
    }
};

int main() {
    Number num(25);
    cout << "Before Negation: "; num.display();
    
    -num; 
    cout << "After Negation: "; num.display();

    return 0;
}
