//Binary Operator Overloading 
#include <iostream>
using namespace std;

class Distance {
private:
    int meters;
    int centimeters;

public:
    Distance(int m = 0, int cm = 0) {
        meters = m;
        centimeters = cm;
    }

    Distance operator+(const Distance &d) {
        int totalCm = centimeters + d.centimeters;
        int totalM = meters + d.meters + (totalCm / 100);
        totalCm %= 100;
        return Distance(totalM, totalCm);
    }

    void display() const {
        cout << meters << "m " << centimeters << "cm" << endl;
    }
};

int main() {
    Distance d1(5, 80), d2(3, 40);
    Distance d3 = d1 + d2;

    cout << "Distance 1: "; d1.display();
    cout << "Distance 2: "; d2.display();
    cout << "Summed Distance: "; d3.display();

    return 0;
}
