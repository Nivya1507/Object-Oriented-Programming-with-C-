//Memory Management with Employee Class
#include <iostream>
#include <string>
using namespace std;

class Employee {
private:
    string* name;
    double salary;

public:
    Employee(string n, double s) {
        name = new string(n);
        salary = s;
        cout << "Constructor called for " << *name << endl;
    }

    ~Employee() {
        cout << "Destructor called for " << *name << endl;
        delete name;
    }

    void display() const {
        cout << "Employee: " << *name << " | Salary: $" << salary << endl;
    }
};

int main() {
    Employee emp("John Doe", 75000);
    emp.display();
    return 0;
}
