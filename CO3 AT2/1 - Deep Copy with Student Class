#include <iostream>
#include <string>
using namespace std;

class Student {
private:
    string* name;
    int marks;

public:
    Student(string n, int m) {
        name = new string(n);
        marks = m;
    }

    Student(const Student &s) {
        name = new string(*(s.name)); // Deep copy allocation
        marks = s.marks;
    }

    ~Student() {
        delete name;
    }

    void modifyName(string newName) {
        *name = newName;
    }

    void display() const {
        cout << "Name: " << *name << ", Marks: " << marks << endl;
    }
};

int main() {
    Student s1("Alice", 90);
    Student s2 = s1; // Calls copy constructor

    cout << "Initial Objects:\n";
    s1.display();
    s2.display();

    s2.modifyName("Bob");

    cout << "\nAfter Modifying Copied Object:\n";
    s1.display();
    s2.display();

    return 0;
}
